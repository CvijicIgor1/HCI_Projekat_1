<Window x:Class="Sistem_za_upravljanje_sadrzajima.VisitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sistem_za_upravljanje_sadrzajima"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="VisitWindow" Height="770" Width="820">

    <Grid Background="#ADD8E6">
        <Grid.RowDefinitions>
            <RowDefinition Height="230"/>
            <RowDefinition Height="170"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        
        <Grid Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="70"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

           
            <Label Grid.Row="0" Grid.Column="0"
                   x:Name="ArtistCommonLabel"
                   Foreground="Black"
                   Content="Artist:"
                   FontWeight="Normal"
                   FontSize="25"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"/>

            <Label Grid.Row="0" Grid.Column="1"
                   x:Name="ArtistNameLabel"
                   Foreground="Black"
                   Content="{Binding ArtistName}"
                   FontWeight="DemiBold"
                   FontSize="25"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Margin="15,0,0,0"
                   MaxWidth="240"/>

            
            <Label Grid.Row="1" Grid.Column="0"
                   x:Name="SongCommonTitle"
                   Foreground="Black"
                   Content="Title Of Song:"
                   FontWeight="Normal"
                   FontSize="25"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"/>

            <Label Grid.Row="1" Grid.Column="1"
                   x:Name="SongTitleLabel"
                   Foreground="Black"
                   Content="{Binding SongTitle}"
                   FontWeight="DemiBold"
                   FontSize="25"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Margin="15,0,0,0"
                   MaxWidth="240"/>

           
            <Label Grid.Row="2" Grid.Column="0"
                   x:Name="GradeCommonFansLabel"
                   Foreground="Black"
                   Content="Grade:"
                   FontWeight="Normal"
                   FontSize="25"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"/>

            <Label Grid.Row="2" Grid.Column="1"
                   x:Name="GradeOfFansLabel"
                   Foreground="Black"
                   Content="{Binding GradeOfFans}"
                   FontWeight="DemiBold"
                   FontSize="25"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Margin="15,0,0,0"
                   MaxWidth="240"/>
        </Grid>

       
        <Grid Grid.Row="1">
            <Label 
                x:Name="ImageCommonLabel"
                Foreground="Black"
                Content="Image:"
                FontWeight="DemiBold"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Margin="0,0,0,0"
                FontSize="25"/>

            <Image 
                x:Name="PreviewImageImage"
                Source="{Binding ArtistImage}" 
                Width="250" 
                Height="90"
                HorizontalAlignment="Center" 
                VerticalAlignment="Top" 
                Margin="0,50,0,0" 
                Stretch="Uniform"/>
        </Grid>

        
        <Grid Grid.Row="2">
            <Label 
                x:Name="ReviewCommonLabel"
                Foreground="Black"
                Content="Review:"
                FontWeight="DemiBold"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Margin="0,0,0,0"
                FontSize="25"/>

            <Border Background="#FFFFF0" 
                    BorderBrush="Transparent" 
                    BorderThickness="0"
                    Margin="10,45,10,10">

                <FlowDocumentScrollViewer 
                    x:Name="ReviewDocumentViewer"
                    VerticalScrollBarVisibility="Auto"
                    IsToolBarVisible="False" 
                    IsSelectionEnabled="False"
                    Background="Transparent"
                    BorderThickness="0">

                    <FlowDocument Background="#FFFFF0" PagePadding="15">
                        <Paragraph>
                            <Run Text="{Binding ReviewText}" 
                                 Foreground="#C25B5B" 
                                 FontSize="20"/>
                        </Paragraph>
                    </FlowDocument>

                </FlowDocumentScrollViewer>
            </Border>
        </Grid>

    </Grid>
</Window>