<Window x:Class="Sistem_za_upravljanje_sadrzajima.AddArtistInTable"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sistem_za_upravljanje_sadrzajima"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Title="AddArtistInTable" Height="770" Width="820">

    <Grid Background="#C0C0C0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        
        <Label
            x:Name="UnosKorisnikaLabel"
            Content="ADD BALKAN ARTIST"
            Grid.Column="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="36"
            FontWeight="DemiBold"
            Foreground="Black">
            <Label.LayoutTransform>
                <RotateTransform Angle="-90"/>
            </Label.LayoutTransform>
        </Label>

        
        <StackPanel Grid.Column="1" Margin="10" Orientation="Vertical">

            
            <Label Content="Artist:" FontWeight="DemiBold" FontSize="18" Margin="0,5,0,0"/>
            <TextBox x:Name="ArtistNameTextBox" Width="250" LostFocus="ArtistNameTextBox_LostFocus" GotFocus="ArtistNameTextBox_GotFocus" />

            
            <Label Content="Title of Song:" FontWeight="DemiBold" FontSize="18" Margin="0,10,0,0"/>
            <TextBox x:Name="TitleOfSongTextBox" Width="250" GotFocus="TitleOfSongTextBox_GotFocus" LostFocus="TitleOfSongTextBox_LostFocus"  />

            
            <Label Content="Grade Of Fan:" FontWeight="DemiBold" FontSize="18" Margin="0,10,0,0"/>
            <TextBox x:Name="GradeOfFanTextBox" Width="250" PreviewTextInput="GradeOfFanTextBox_PreviewTextInput" LostFocus="GradeOfFanTextBox_LostFocus" GotFocus="GradeOfFanTextBox_GotFocus"   />

           
            <Label Content="Image:" FontWeight="DemiBold" FontSize="18" Margin="0,10,0,0"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="PreviewImageButton" Content="Browse..." Width="80" Height="30" Click="PreviewImageButton_Click" Background="#FFFFF0"  />
                <Image x:Name="PreviewImage" Grid.Column="1" Width="180" Height="100" Margin="0,0,0,0" Stretch="Uniform"/>
            </Grid>

            <Label Content="Review:" FontWeight="DemiBold" FontSize="18" Margin="0,10,0,0"/>

            <DockPanel LastChildFill="True">
                
                <ToolBar DockPanel.Dock="Top">
                    <ToggleButton x:Name="BoldToggleButton" Command="EditingCommands.ToggleBold" ToolTip="Bold">B</ToggleButton>
                    <ToggleButton x:Name="ItalicToggleButton" Command="EditingCommands.ToggleItalic" ToolTip="Italic">I</ToggleButton>
                    <ToggleButton x:Name="UnderlineToggleButton" Command="EditingCommands.ToggleUnderline" ToolTip="Underline">U</ToggleButton>
                    <ComboBox x:Name="FontFamilyComboBox" Width="120" SelectionChanged="FontFamilyComboBox_SelectionChanged" >
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock 
                                       Text="{Binding}"
                                       FontFamily="{Binding}"
                                       FontSize="10"/>  
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <ComboBox x:Name="FontSizeComboBox" Width="60" SelectionChanged="FontSizeComboBox_SelectionChanged"  />
                    <Button Content="Color" />
                    <ComboBox x:Name="ColorComboBox"
                              Width="140" SelectionChanged="ColorComboBox_SelectionChanged" 
                              
                              >
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="16"
                                               Height="16"
                                               Fill="{Binding Brush}"
                                               Stroke="Black"
                                               Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding Name}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </ToolBar>


                <RichTextBox x:Name="DescriptionRichTextBox" Height="150" Margin="0,5,0,0" TextChanged="DescriptionRichTextBox_TextChanged" SelectionChanged="DescriptionRichTextBox_SelectionChanged" />
            </DockPanel>

           
            <StatusBar>
                <StatusBarItem>
                    <TextBlock x:Name="WordCountTextBlock" Text="Words: 0"/>
                </StatusBarItem>
            </StatusBar>

            
            <Label x:Name="DateAddedLabel" Content="Date: [at this moment datetime]"  Margin="0,10,0,0"/>


            <Button x:Name="ButtonAddStudent" 
                    FontSize="16"
                    Content="Add Artist" 
                    Width="120" Height="35" 
                    Margin="0,10,0,0" 
                    Click="ButtonAddStudent_Click" 
                    Background="#FFFFF0" />
            
            <Button x:Name="ButtonLeavePage" 
                    FontSize="16"
                    Content="Leave Page" 
                    Width="120" Height="35" 
                    Margin="0,10,0,0" 
                    Click="ButtonLeavePage_Click" 
                    Background="#FFFFF0"  />
        </StackPanel>
    </Grid>
</Window>