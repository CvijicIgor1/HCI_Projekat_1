<Window x:Class="Sistem_za_upravljanje_sadrzajima.EditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sistem_za_upravljanje_sadrzajima"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Title="EditArtistWindow" Height="770" Width="820">
    <Grid Background="#C0C0C0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <Label
         x:Name="UnosKorisnikaLabel"
         Content="EDIT BALKAN ARTIST"
         Grid.Column="0"
         HorizontalAlignment="Center"
         VerticalAlignment="Center"
         FontSize="36"
         FontWeight="DemiBold"
         Foreground="Black">
            <Label.LayoutTransform>
                <RotateTransform Angle="-90"/>
            </Label.LayoutTransform>
        </Label>


        <StackPanel Grid.Column="1" Margin="10" Orientation="Vertical">


            <Label Content="Artist:" FontWeight="DemiBold" FontSize="18" Margin="0,5,0,0"/>
            <TextBox x:Name="EditArtistNameTextBox" Width="250" />


            <Label Content="Title of Song:" FontWeight="DemiBold" FontSize="18" Margin="0,10,0,0"/>
            <TextBox x:Name="EditTitleOfSongTextBox" Width="250"  />


            <Label Content="Grade Of Fan:" FontWeight="DemiBold" FontSize="18" Margin="0,10,0,0"/>
            <TextBox x:Name="EditGradeOfFanTextBox" Width="250"    />


            <Label Content="Image:" FontWeight="DemiBold" FontSize="18" Margin="0,10,0,0"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="EditPreviewImageButton" Content="Browse..." Width="80" Height="30"  Background="#FFFFF0" Click="EditPreviewImageButton_Click"  />
                <Image x:Name="EditPreviewImage" Grid.Column="1" Width="180" Height="100" Margin="0,0,0,0" Stretch="Uniform"/>
            </Grid>

            <Label Content="Review:" FontWeight="DemiBold" FontSize="18" Margin="0,10,0,0"/>

            <DockPanel LastChildFill="True">

                <ToolBar DockPanel.Dock="Top">
                    <ToggleButton x:Name="EditBoldToggleButton" Command="EditingCommands.ToggleBold" ToolTip="Bold">B</ToggleButton>
                    <ToggleButton x:Name="EditItalicToggleButton" Command="EditingCommands.ToggleItalic" ToolTip="Italic">I</ToggleButton>
                    <ToggleButton x:Name="EditUnderlineToggleButton" Command="EditingCommands.ToggleUnderline" ToolTip="Underline">U</ToggleButton>
                    <ComboBox x:Name="EditFontFamilyComboBox" Width="120" SelectionChanged="EditFontFamilyComboBox_SelectionChanged"  >
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock 
                                    Text="{Binding}"
                                    FontFamily="{Binding}"
                                    FontSize="10"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <ComboBox x:Name="EditFontSizeComboBox" Width="60" SelectionChanged="EditFontSizeComboBox_SelectionChanged"   />
                    <Button Content="Color" />
                    <ComboBox x:Name="EditColorComboBox"
                           Width="140" SelectionChanged="EditColorComboBox_SelectionChanged" 
                           
                           >
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="16"
                                            Height="16"
                                            Fill="{Binding Brush}"
                                            Stroke="Black"
                                            Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding Name}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </ToolBar>


                <RichTextBox x:Name="EditDescriptionRichTextBox" Height="150" Margin="0,5,0,0" TextChanged="EditDescriptionRichTextBox_TextChanged" SelectionChanged="EditDescriptionRichTextBox_SelectionChanged"/>
            </DockPanel>


            <StatusBar>
                <StatusBarItem>
                    <TextBlock x:Name="EditWordCountTextBlock" Text="Words: 0"/>
                </StatusBarItem>
            </StatusBar>


            <Label x:Name="EditDateAddedLabel" Content="Date: [at this moment datetime]"  Margin="0,10,0,0"/>


            <Button x:Name="ButtonEditStudent" 
                 FontSize="16"
                 Content="Edit Artist" 
                 Width="120" Height="35" 
                 Margin="0,10,0,0" 
                 Background="#FFFFF0" Click="ButtonEditStudent_Click" />

            <Button x:Name="EditButtonLeavePage" 
                 FontSize="16"
                 Content="Leave Page" 
                 Width="120" Height="35" 
                 Margin="0,10,0,0" 
                 Background="#FFFFF0" Click="EditButtonLeavePage_Click"  />
        </StackPanel>
    </Grid>
</Window>
