<Window x:Class="Sistem_za_upravljanje_sadrzajima.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sistem_za_upravljanje_sadrzajima"
        mc:Ignorable="d"
        Title="Komercijalna Muzika Balkana" 
        Height="450" Width="380" 
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        FontStyle="Normal"
        FontFamily="MS Reference Sans Serif"
        Closing="Window_Closing"
        ResizeMode="NoResize">
    <Grid>
        <Path
            Fill="#6495ED"
            Stroke="#C0C0C0"
            StrokeThickness="5"
            Stretch="Fill">
            <Path.Data>
                <PathGeometry>
                    <PathFigure StartPoint="20,0" IsClosed="True">
                        <LineSegment Point="360,0"/>
                        <LineSegment Point="380,20"/>
                        <LineSegment Point="380,430"/>
                        <LineSegment Point="360,450"/>
                        <LineSegment Point="20,450"/>
                        <LineSegment Point="0,430"/>
                        <LineSegment Point="0,20"/>
                    </PathFigure>
                </PathGeometry>
            </Path.Data>
        </Path>
        
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label
                x:Name="LogInLabel"
                Content="LOG IN"
                Grid.Row="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="40"
                FontWeight="DemiBold"
                Foreground="AliceBlue"
                />
            <Label
                x:Name="UsernameLabel"
                Content="Username:"
                Grid.Row="1"
                HorizontalAlignment="Left"
                Margin="40,0,0,0"
                VerticalAlignment="Center"
                FontWeight="SemiBold"
                FontSize="18"
                Foreground="AliceBlue"
                />
            <Label
                x:Name="PasswordLabel"
                Content="Password:"
                Grid.Row="2"
                HorizontalAlignment="Left"
                Margin="40,0,0,0"
                VerticalAlignment="Center"
                FontWeight="SemiBold"
                FontSize="18"
                Foreground="AliceBlue"
                 />
            <TextBox
                x:Name="UsernameTextBoxLogInTab"
                Grid.Row="1"
                HorizontalAlignment="Right"
                Margin="0,0,50,0"
                VerticalAlignment="Center"
                Width="160"
                Height="22"
                TextAlignment="Left"
                Padding="0,2,0,2" 
                />
            <PasswordBox
                x:Name="PasswordBoxPasswordLogInTab"
                FontWeight="Normal"
                Grid.Row="2"
                HorizontalAlignment="Right"
                Margin="0,0,50,0"
                VerticalAlignment="Center"
                Width="160"
                Height="22"
                Padding="0,2,0,2" 
                />
            <Button
                x:Name="CloseButton"
                Content="Close"
                Grid.Row="3"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Margin="50,31,0,50"
                Width="80"
                Height="28"
                FontWeight="Heavy" Click="CloseButton_Click"
                Background="#C0C0C0"
                />
            <Button
                x:Name="LogInButton"
                Content="Log In"
                Grid.Row="3"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,31,50,50"
                Width="80"
                Height="28"
                FontWeight="Heavy"
                Background="#C0C0C0" Click="LogInButton_Click"
                />
        </Grid>
        
    </Grid>
</Window>
